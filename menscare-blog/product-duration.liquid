{%- comment -%}
  MEN'S CARE — Product Duration pill (per quantity-breaks card)
  Shows how long the chosen quantity lasts in days.
  Required params: product, quantity
{%- endcomment -%}

{%- liquid
  assign days_per_unit = 0
  case product.handle
    when 'серум-за-растеж-на-брада-60ml'
      assign days_per_unit = 40
    when 'пяна-за-растеж-на-брада-60ml'
      assign days_per_unit = 45
    when 'масло-за-брада-30ml'
      assign days_per_unit = 60
    when 'серум-за-растеж-на-коса-60ml'
      assign days_per_unit = 40
    when 'пяна-за-растеж-на-коса-60ml'
      assign days_per_unit = 45
    when 'комплект-ускорен-растеж'
      assign days_per_unit = 40
    when 'комплект-максимален-растеж'
      assign days_per_unit = 45
    when 'комплект-за-брада-mega-pack'
      assign days_per_unit = 45
    when 'комплект-за-коса-ускорен-растеж'
      assign days_per_unit = 40
    when 'комплект-за-коса-максимален-растеж'
      assign days_per_unit = 45
  endcase

  assign total_days = quantity | times: days_per_unit
  assign unit_label = 'дни'
  if total_days == 1
    assign unit_label = 'ден'
  endif
-%}

{%- if total_days > 0 -%}
  <span class="mc-duration">
    <svg class="mc-duration__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <path d="M12 7v5l3 2"/>
    </svg>
    <span class="mc-duration__text">Стига за <strong>{{ total_days }} {{ unit_label }}</strong></span>
  </span>
  <style>
    .mc-duration {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      background: #f4ecda;
      color: #2a1f14;
      font-size: 11.5px;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.005em;
      width: fit-content;
      max-width: 100%;
      white-space: nowrap;
    }
    .mc-duration__icon {
      width: 12px;
      height: 12px;
      flex-shrink: 0;
      color: #2a1f14;
      opacity: 0.85;
    }
    .mc-duration strong { font-weight: 700; }

    @media (max-width: 749px) {
      .mc-duration {
        font-size: 9px;
        padding: 2px 6px;
        gap: 3px;
        margin-top: 4px;
        max-width: 100%;
      }
      .mc-duration__icon { width: 9px; height: 9px; }
      .mc-duration__text {
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
      }

      /* Minimal fix: prevent 3rd card overflow without changing layout */
      .quantity-breaks-container > * {
        min-width: 0;
      }
    }
    @media (max-width: 380px) {
      .mc-duration {
        font-size: 8.5px;
        padding: 2px 5px;
        gap: 2px;
      }
      .mc-duration__icon { width: 8px; height: 8px; }
    }

    /* Auto-savings — inherit theme caption styling (matches single products) */
  </style>
{%- endif -%}
