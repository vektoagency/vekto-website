{%- comment -%}
  MEN'S CARE — Product Timeline pill for collection cards
  Renders a small "Резултати: X-Y седмици" pill on the product card.
  Skipped for products where timeline doesn't apply (oil, dermaroller).
{%- endcomment -%}

{%- liquid
  assign timeline = ''
  case card_product.handle
    when 'серум-за-растеж-на-брада-60ml'
      assign timeline = '8-12 седмици'
    when 'пяна-за-растеж-на-брада-60ml'
      assign timeline = '4-8 седмици'
    when 'серум-за-растеж-на-коса-60ml'
      assign timeline = '6-12 седмици'
    when 'пяна-за-растеж-на-коса-60ml'
      assign timeline = '4-8 седмици'
    when 'комплект-ускорен-растеж'
      assign timeline = '8-12 седмици'
    when 'комплект-максимален-растеж'
      assign timeline = '4-8 седмици'
    when 'комплект-за-брада-mega-pack'
      assign timeline = '8-12 седмици'
    when 'комплект-за-коса-ускорен-растеж'
      assign timeline = '6-12 седмици'
    when 'комплект-за-коса-максимален-растеж'
      assign timeline = '4-8 седмици'
  endcase
-%}

{%- if timeline != blank -%}
  <div class="mc-card-timeline" aria-label="Очаквани резултати при редовна употреба">
    <svg class="mc-card-timeline__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"/>
      <path d="M12 7v5l3 2"/>
    </svg>
    <span class="mc-card-timeline__text">Първи резултати: <strong>{{ timeline }}</strong></span>
  </div>
  <style>
    .mc-card-timeline {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 9px;
      margin: 6px 0 4px;
      border-radius: 999px;
      background: #f5f0e3;
      color: #2a1f14;
      font-size: 11px;
      line-height: 1.2;
      letter-spacing: -0.005em;
    }
    .mc-card-timeline__icon { width: 12px; height: 12px; flex-shrink: 0; }
    .mc-card-timeline__text strong { font-weight: 700; }
    @media (min-width: 750px) {
      .mc-card-timeline { font-size: 11.5px; padding: 4px 10px; }
      .mc-card-timeline__icon { width: 13px; height: 13px; }
    }
    .quantity-breaks__timeline-wrap {
      text-align: center;
      margin: 4px 0 12px;
    }
    .quantity-breaks__timeline-wrap .mc-card-timeline {
      padding: 6px 14px;
      font-size: 12.5px;
      background: #fffaf0;
      border: 1px solid rgba(221, 29, 29, 0.18);
    }
    .quantity-breaks__timeline-wrap .mc-card-timeline__icon { width: 14px; height: 14px; }
  </style>
{%- endif -%}
