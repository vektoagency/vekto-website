{%- comment -%}
  MEN'S CARE — Product Benefits Trust Strip
  3 benefit pills under the price on product pages.
  Mapped per product handle. Add new product? Just add a 'when' branch.
{%- endcomment -%}

{%- liquid
  case product.handle
    when 'серум-за-растеж-на-брада-60ml'
      assign i1 = 'hair'   | append: '|За редки зони · първи резултати за 2-6 седмици'
      assign i2 = 'shield' | append: '|Подходящ и за чувствителна кожа'
      assign i3 = 'star'   | append: '|Доверен от 10,000+ мъже в България'
    when 'пяна-за-растеж-на-брада-60ml'
      assign i1 = 'hair'   | append: '|За бузите · първи резултати за 2-6 седмици'
      assign i2 = 'shield' | append: '|Лек на кожата, не омазнява'
      assign i3 = 'star'   | append: '|Доверен от 10,000+ мъже в България'
    when 'масло-за-брада-30ml'
      assign i1 = 'drop'   | append: '|Облекчава сърбежа от първото нанасяне'
      assign i2 = 'leaf'   | append: '|Подхранва брадата и кожата'
      assign i3 = 'shield' | append: '|Без синтетични аромати — мек на кожата'
    when 'дермаролер'
      assign i1 = 'shield' | append: '|С правилна техника не боли'
      assign i2 = 'hair'   | append: '|Подкрепя ефекта на серума и пяната'
      assign i3 = 'check'  | append: '|Стерилно опаковано — лесен за домашна употреба'
    when 'дермаролер-1'
      assign i1 = 'shield' | append: '|С правилна техника не боли'
      assign i2 = 'hair'   | append: '|Подкрепя ефекта на серума и пяната'
      assign i3 = 'check'  | append: '|Стерилно опаковано — лесен за домашна употреба'
    when 'серум-за-растеж-на-коса-60ml'
      assign i1 = 'hair'   | append: '|Срещу косопада · първи резултати за 2-6 седмици'
      assign i2 = 'shield' | append: '|Подходящ и за чувствителен скалп'
      assign i3 = 'star'   | append: '|Доверен от 10,000+ клиенти в България'
    when 'пяна-за-растеж-на-коса-60ml'
      assign i1 = 'hair'   | append: '|За обем и плътност · първи резултати за 2-6 седмици'
      assign i2 = 'shield' | append: '|Лек на скалпа — за всички типове'
      assign i3 = 'star'   | append: '|Доверен от 10,000+ клиенти в България'
    when 'комплект-ускорен-растеж'
      assign i1 = 'hair'   | append: '|Серум + Дермаролер — комбинация за по-силен ефект'
      assign i2 = 'star'   | append: '|Доверен от 10,000+ мъже в България'
      assign i3 = 'check'  | append: '|Гаранция за връщане на парите · 120 дни'
    when 'комплект-максимален-растеж'
      assign i1 = 'hair'   | append: '|Пяна + Дермаролер — комбинация за по-силен ефект'
      assign i2 = 'star'   | append: '|Доверен от 10,000+ мъже в България'
      assign i3 = 'check'  | append: '|Гаранция за връщане на парите · 120 дни'
    when 'комплект-за-брада-mega-pack'
      assign i1 = 'hair'   | append: '|Пълна рутина: серум, пяна, масло и дермаролер'
      assign i2 = 'star'   | append: '|Доверен от 10,000+ мъже в България'
      assign i3 = 'shield' | append: '|Достатъчно за пълна 3-месечна рутина'
    when 'комплект-за-коса-ускорен-растеж'
      assign i1 = 'hair'   | append: '|Серум + Дермаролер — комбинация за косата'
      assign i2 = 'star'   | append: '|Доверен от 10,000+ клиенти в България'
      assign i3 = 'shield' | append: '|Подходящ и за чувствителен скалп'
    when 'комплект-за-коса-максимален-растеж'
      assign i1 = 'hair'   | append: '|Пяна + Дермаролер — комбинация за косата'
      assign i2 = 'star'   | append: '|Доверен от 10,000+ клиенти в България'
      assign i3 = 'shield' | append: '|Подходящ за всички типове скалп'
    else
      assign i1 = 'hair'   | append: '|Подкрепя растежа при редовна употреба'
      assign i2 = 'shield' | append: '|Подходящ и за чувствителна кожа'
      assign i3 = 'star'   | append: '|Доверен от 10,000+ клиенти в България'
  endcase

  assign items = '' | split: ''
  assign items = items | concat: i1
  assign items = items | concat: '|||' | split: '|||'
-%}

<div class="mc-benefits" data-benefits-strip>
  {%- assign list = i1 | append: ',,' | append: i2 | append: ',,' | append: i3 | split: ',,' -%}
  {%- for raw in list -%}
    {%- assign p = raw | split: '|' -%}
    {%- assign icon = p[0] -%}
    {%- assign title = p[1] -%}
    <div class="mc-benefits__item">
      <div class="mc-benefits__icon" aria-hidden="true">
        {%- case icon -%}
          {%- when 'leaf' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13c0-7 7-9 17-9 0 9-3 16-10 16Z"/><path d="M2 21c0-3 3-7 9-9"/></svg>
          {%- when 'shield' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
          {%- when 'truck' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h11v10H2zM13 11h6l3 3v3h-9z"/><circle cx="6" cy="19" r="2"/><circle cx="17" cy="19" r="2"/></svg>
          {%- when 'star' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 3.1 6.5L22 9.7l-5 4.9 1.2 7-6.2-3.3L5.8 21.6 7 14.6 2 9.7l6.9-1.2Z"/></svg>
          {%- when 'check' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          {%- when 'lab' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v8L4 22h16L14 10V2"/><path d="M8 2h8"/></svg>
          {%- when 'hair' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a8 8 0 0 1 16 0v6H4z"/><path d="M7 4c2 0 3 2 5 2s3-2 5-2"/><path d="M5 9c2-1 3-3 5-3s3 2 5 2 3 0 4-1"/></svg>
          {%- when 'drop' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2s7 7 7 12a7 7 0 0 1-14 0c0-5 7-12 7-12z"/></svg>
          {%- else -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
        {%- endcase -%}
      </div>
      <div class="mc-benefits__title">{{ title }}</div>
    </div>
  {%- endfor -%}
</div>

<style>
  .mc-benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    padding: 10px 4px;
    margin: 12px 0 14px;
    border-radius: 10px;
    background: #ffffff;
    border: 1px solid #e8e2d4;
    box-shadow: 0 1px 8px rgba(40, 30, 20, 0.04);
    position: relative;
    overflow: hidden;
  }
  .mc-benefits::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, #2ba4c0 50%, transparent 100%);
    opacity: 0.7;
  }
  .mc-benefits__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    text-align: center;
    padding: 2px 6px;
    position: relative;
  }
  .mc-benefits__item + .mc-benefits__item::before {
    content: "";
    position: absolute;
    left: 0; top: 20%; bottom: 20%;
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, #e8e2d4 50%, transparent 100%);
  }
  .mc-benefits__icon {
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    flex-shrink: 0;
    background: linear-gradient(135deg, #2a1f14 0%, #1a1108 100%);
    border-radius: 50%;
    padding: 6px;
    box-shadow: 0 1px 4px rgba(40, 30, 20, 0.15);
  }
  .mc-benefits__icon svg {
    width: 100%;
    height: 100%;
    stroke-width: 2;
  }
  .mc-benefits__title {
    font-size: 10.5px;
    font-weight: 600;
    line-height: 1.3;
    color: #2a1f14;
    letter-spacing: -0.005em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    word-break: break-word;
    hyphens: auto;
  }
  @media (min-width: 750px) {
    .mc-benefits { padding: 12px 6px; }
    .mc-benefits__item { padding: 2px 12px; gap: 7px; }
    .mc-benefits__icon { width: 32px; height: 32px; padding: 7px; }
    .mc-benefits__title { font-size: 12px; -webkit-line-clamp: 3; }
  }
</style>
